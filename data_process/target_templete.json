    {
        "image_path":"./frames/frame_参考原始json.png",
        "objects":[
            {
                "idx":"整数(此数该帧唯一)",
                "box":"[x1,y1,x2,y2]",
                "score":"浮点数,//置信度（场景图模型的输出）",
                "label":"字符串（实体是什么）", 
                "tag":"字符串,（label+数字，因为同一种实体可能有多个，若在该帧中只有一个则没有数字）",
                "attributes":"字符串，（对于该实体的描述）",
                "layer_id":"整数 ,（表示该物体在层次结构中的层级，1为上层）",
                "layer_mapping":[{"idx":"整数（表示该实体在map中指向的实体的idx）",
                                  "tag":"字符串（被指向实体的tag）"},{"idx":"同上",
                                  "tag":"同上"},{"idx":"以此类推",
                                  "tag":"以此类推"},{}],
                "subject_ralations":[{"idx":"整数（客体的idx）",
                                      "predicate":"字符串",
                                      "object_tag":"字符串",
                                      "confidence":"浮点数(关系的置信度)"},{},{},{"含义":"表示该物体作为主体的关系列表"}],
                "object_ralations":[{"idx":"整数（对应主体的idx）",
                                     "predicate":"字符串",
                                     "subject_tag":"字符串",
                                     "confidence":"浮点数(关系的置信度)"},{},{},{"含义":"表示该物体作为客体的关系列表"}]
            }
        ]
    },
    {},
    {"含义":"表示多张图像的场景图列表"}
